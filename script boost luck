if game.PlaceId == 2753915549 or game.PlaceId == 4442272182 or game.PlaceId == 7449423635 then
    -- 1. Load the Rayfield Library Engine
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

    -- 2. Create the Visual Menu Window
    local Window = Rayfield:CreateWindow({
        Name = "Mukesh Hub | Blox Fruits",
        LoadingTitle = "Loading Script...",
        LoadingSubtitle = "by Mukesh",
        ConfigurationSaving = { Enabled = false },
        KeySystem = false
    })

    -- 3. Create a Tab inside the menu
    local GachaTab = Window:CreateTab("Fruit Gacha", 4483362458)

    -- 4. Add the Auto-Fruit Spinner Button
    GachaTab:CreateButton({
        Name = "Buy Random Fruit (Gacha)",
        Callback = function()
            -- Access the game's built-in shop event safely
            local gachaRemote = game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("CommF_")
            
            if gachaRemote then
                -- This fires the real Blox Fruits system to buy a random fruit
                local result = gachaRemote:InvokeServer("Cousin", "Buy")
                
                -- Check the result response in your executor console
                if result then
                    print("Gacha Result: " .. tostring(result))
                    Rayfield:Notify({
                        Title = "Gacha Result",
                        Content = tostring(result),
                        Duration = 5,
                        Image = 4483362458,
                    })
                else
                    Rayfield:Notify({
                        Title = "Error",
                        Content = "Failed to communicate with Gacha server.",
                        Duration = 5,
                        Image = 4483362458,
                    })
                end
            else
                Rayfield:Notify({
                    Title = "Error",
                    Content = "Game remote functions not found!",
                    Duration = 5,
                    Image = 4483362458,
                })
            end
        end,
    })
else
    warn("Script failed: You are not in a Blox Fruits game server.")
end
